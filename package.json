  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@borela-tech/eslint-config": "^3.0.1",
    "@microsoft/api-extractor": "^7.58.5",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.24.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.2"
  },
  "peerDependencies": {
